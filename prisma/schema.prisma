generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String @id @default(cuid())
  email         String @unique
  name          String
  passwordHash  String
  role          String
  departmentId  String
  emailverified String

  department Department @relation(fields: [departmentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Department {
  id    String @id @default(cuid())
  name  String
  code  String @unique
  users User[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
